.venv/
venv/
.env/

# Environment variables — never commit secrets
.env
*.env
.env.local
.env.production

# Test and coverage output
.pytest_cache/
.coverage
htmlcov/
*.coverage

# Build artifacts
dist/
build/
*.egg-info/

# IDE files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Baseline results (generated, not source)
baseline_results.json

# Temp sandbox files (should clean up but just in case)
sandbox_*.py
/tmp/sandbox_*

instructions.md
.gitignore